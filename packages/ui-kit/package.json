{
  "name": "@infinityloop.labs/ui-kit",
  "version": "0.0.11",
  "type": "module",
  "license": "MIT",
  "files": [
    "package.json",
    "README",
    "LICENSE",
    "dist/"
  ],
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "concurrently -k -n STORYBOOK,VISUAL \"npm:storybook:dev\" \"npm:visual:server\"",
    "build": "tsc && vite build",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "storybook:dev": "storybook dev -p 6006 --no-open",
    "storybook": "npm run storybook:dev",
    "build-storybook": "storybook build",
    "test:visual": "node ./scripts/visual/run-visual-tests.mjs",
    "test:visual:update": "node ./scripts/visual/run-visual-tests.mjs --update-snapshots",
    "visual:manifest": "node ./scripts/visual/build-manifest.mjs",
    "visual:server": "node ./scripts/visual/server.mjs"
  },
  "peerDependencies": {
    "react": "19.x.x",
    "react-dom": "19.x.x"
  },
  "devDependencies": {
    "@infinityloop.labs/tailwind-config": "^1.0.18",
    "@infinityloop.labs/types": "^1.0.2",
    "@infinityloop.labs/utils": "^1.0.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react-swc": "^3.4.0",
    "concurrently": "^9.2.1",
    "eslint-plugin-react-refresh": "^0.4.3",
    "eslint-plugin-storybook": "10.3.1",
    "express": "^4.22.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.6",
    "storybook": "^10.3.1",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^3.6.1"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.1.13",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color": "^5.0.3",
    "lucide-react": "^0.546.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "swiper": "^11.2.10",
    "tailwind-merge": "^3.3.1"
  }
}
